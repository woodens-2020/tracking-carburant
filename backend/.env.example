# ── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:VOTRE_MOT_DE_PASSE@localhost:5432/station_db

# ── Sécurité ─────────────────────────────────────────────────────────────────
ADMIN_API_KEY=changez-moi-en-production
GEMINI_API_KEY=votre-cle-gemini
GOOGLE_CLIENT_ID=votre-google-client-id
GOOGLE_CLIENT_SECRET=votre-google-client-secret

# ── OTP — Vérification en deux étapes ────────────────────────────────────────
# Activez ou désactivez le 2FA par email (true | false)
OTP_ENABLED=true

# Paramètres avancés (valeurs par défaut recommandées)
OTP_DURATION_MINUTES=5      # Durée de validité du code (minutes)
OTP_MAX_ATTEMPTS=3          # Tentatives max avant invalidation
OTP_RATE_LIMIT=3            # Max demandes OTP par fenêtre
OTP_RATE_WINDOW_MINUTES=10  # Fenêtre de rate limiting (minutes)

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# IMPORTANT : EMAIL_HOST_PASSWORD = MOT DE PASSE D'APPLICATION Gmail
#             PAS le mot de passe de votre compte Google !
#
# Pour créer un mot de passe d'application :
#   1. Connectez-vous à myaccount.google.com
#   2. Sécurité → Vérification en deux étapes (doit être activée)
#   3. Sécurité → Mots de passe des applications
#   4. Sélectionnez "Autre (nom personnalisé)" → entrez "Konekta"
#   5. Cliquez "Générer" → copiez le mot de passe de 16 caractères
#   6. Collez-le ci-dessous (sans espaces)
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre-adresse@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=Konekta · Bon Prix
